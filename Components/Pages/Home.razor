@page "/"
@rendermode InteractiveServer
@attribute [Authorize]
@inject HabitService HabitService
@inject UserManager<User> UserManager
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Dashboard — Brodihy</PageTitle>

@if (isLoading)
{
    <div class="welcome-banner" style="min-height: 138px;">
        <div class="skeleton" style="width:220px; height:24px; margin-bottom:10px; background:rgba(255,255,255,0.13); animation:shimmer 1.4s infinite linear;"></div>
        <div class="skeleton" style="width:160px; height:14px; background:rgba(255,255,255,0.08); animation:shimmer 1.4s infinite linear;"></div>
    </div>

    <div class="stats-grid">
        @for (int i = 0; i < 4; i++)
        {
            <div class="stat-card">
                <div class="skeleton" style="width:40px; height:40px; border-radius:10px;"></div>
                <div class="skeleton" style="width:52px; height:30px; border-radius:6px;"></div>
                <div class="skeleton" style="width:90px; height:12px;"></div>
            </div>
        }
    </div>

    <div class="content-grid">
        <div class="card">
            <div class="skeleton" style="width:130px; height:16px; margin-bottom:20px;"></div>
            <div class="skeleton" style="width:100%; height:13px; margin-bottom:10px;"></div>
            <div class="skeleton" style="width:80%;  height:13px; margin-bottom:10px;"></div>
            <div class="skeleton" style="width:90%;  height:13px;"></div>
        </div>
        <div class="card">
            <div class="skeleton" style="width:100px; height:16px; margin-bottom:20px;"></div>
            <div class="skeleton" style="width:100%; height:13px; margin-bottom:10px;"></div>
            <div class="skeleton" style="width:70%;  height:13px;"></div>
        </div>
    </div>
}
else
{
    <div class="welcome-banner">
        <div class="welcome-greeting">Good @greeting, @displayName</div>
        <div class="welcome-sub">
            @if (totalHabits == 0)
            {
                <span>Ready to start your habit journey? Add your first habit.</span>
            }
            else
            {
                <span>You have @totalHabits active habit@(totalHabits != 1 ? "s" : "") to track today.</span>
            }
        </div>
        <div class="welcome-actions">
            <a href="/habits/new" class="btn btn-white btn-sm">
                <i class="bi bi-plus-lg"></i> Add Habit
            </a>
            <a href="/habits" class="btn btn-outline-white btn-sm">
                <i class="bi bi-list-check"></i> View All
            </a>
        </div>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-card-icon icon-indigo"><i class="bi bi-list-check"></i></div>
            <div class="stat-card-value">@totalHabits</div>
            <div class="stat-card-label">Active habits</div>
        </div>
        <div class="stat-card">
            <div class="stat-card-icon icon-green"><i class="bi bi-check2-all"></i></div>
            <div class="stat-card-value">@completedToday</div>
            <div class="stat-card-label">Completed today</div>
        </div>
        <div class="stat-card">
            <div class="stat-card-icon icon-amber"><i class="bi bi-fire"></i></div>
            <div class="stat-card-value">@currentStreak</div>
            <div class="stat-card-label">Day streak</div>
        </div>
        <div class="stat-card">
            <div class="stat-card-icon icon-rose"><i class="bi bi-graph-up"></i></div>
            <div class="stat-card-value">@weeklyTotal</div>
            <div class="stat-card-label">This week</div>
        </div>
    </div>

    <div class="content-grid">
        <div class="card">
            <div class="card-header">
                <span class="card-title">Today's Habits</span>
                <a href="/habits" style="font-size:12.5px; text-decoration:none; font-weight:500;">See all</a>
            </div>

            @if (habits.Count == 0)
            {
                <div class="empty-state">
                    <span class="empty-state-icon"><i class="bi bi-journal-plus"></i></span>
                    <div class="empty-state-title">No habits yet</div>
                    <p class="empty-state-desc">
                        Create your first habit to start tracking your daily progress.
                    </p>
                    <a href="/habits/new" class="btn btn-primary" style="width:auto; padding:10px 20px;">
                        <i class="bi bi-plus-lg"></i> Add your first habit
                    </a>
                </div>
            }
            else
            {
                <div style="display:flex; flex-direction:column; gap:10px;">
                    @foreach (var habit in habits)
                    {
                        <div style="display:flex; align-items:center; gap:12px; padding:12px; border:1px solid var(--border); border-radius:var(--radius-sm);">
                            <div style="width:36px; height:36px; border-radius:9px; background:var(--primary-light); display:flex; align-items:center; justify-content:center; font-size:15px; flex-shrink:0; color:var(--primary);">
                                @((MarkupString)GetHabitIcon(habit.Type))
                            </div>
                            <div style="flex:1; min-width:0;">
                                <div style="font-size:13.5px; font-weight:500;">@habit.Name</div>
                                <div style="font-size:12px; color:var(--text-muted); font-weight:400;">@habit.Type &middot; @habit.WeeklyFrequency&times;/week</div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <div style="display:flex; flex-direction:column; gap:16px;">
            <div class="card">
                <div class="card-header" style="margin-bottom:14px;">
                    <span class="card-title">Breakdown</span>
                </div>
                <div style="display:flex; flex-direction:column; gap:9px;">
                    @foreach (var (label, count) in GetBreakdown())
                    {
                        <div style="display:flex; justify-content:space-between; font-size:13px;">
                            <span style="color:var(--text-secondary);">@label</span>
                            <span style="font-weight:500;">@count</span>
                        </div>
                    }
                </div>
            </div>

            <div class="card" style="background:linear-gradient(135deg,#F0F4FF,#E8F5E9);">
                <div style="color:var(--primary); font-size:20px; margin-bottom:8px;">
                    <i class="bi bi-lightbulb"></i>
                </div>
                <div style="font-size:13.5px; font-weight:500; margin-bottom:5px;">Daily tip</div>
                <div style="font-size:12.5px; color:var(--text-secondary); line-height:1.7; font-weight:400;">
                    Consistency beats perfection. Even completing one habit today keeps your momentum going.
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private string displayName = "there";
    private string greeting    = "day";

    private List<Habit> habits = new();
    private int totalHabits;
    private int completedToday;
    private int currentStreak;
    private int weeklyTotal;

    protected override async Task OnInitializedAsync()
    {
        greeting = GetGreeting();

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        if (!string.IsNullOrEmpty(userId))
        {
            var user = await UserManager.FindByIdAsync(userId);
            if (user != null)
            {
                var fullName = $"{user.FirstName} {user.LastName}".Trim();
                displayName = string.IsNullOrEmpty(fullName)
                    ? (user.UserName?.Split('@')[0] ?? "there")
                    : fullName.Split(' ')[0];

                habits      = await HabitService.GetUserHabitsAsync(userId);
                totalHabits = habits.Count;
                completedToday = habits.Count(h => h.Completions.Any(c => c.CompletionDate.Date == DateTime.Today));

                foreach (var habit in habits)
                    weeklyTotal += await HabitService.GetWeeklyProgressAsync(habit.Id, userId);
            }
        }

        isLoading = false;
    }

    private static string GetGreeting()
    {
        var h = DateTime.Now.Hour;
        return h < 12 ? "morning" : h < 18 ? "afternoon" : "evening";
    }

    private IEnumerable<(string Label, int Count)> GetBreakdown() =>
    [
        ("Total habits",     habits.Count),
        ("Physical",         habits.Count(h => h.Type == HabitType.Physical)),
        ("Mental",           habits.Count(h => h.Type == HabitType.Mental)),
        ("Social/Emotional", habits.Count(h => h.Type == HabitType.SocialEmotional)),
        ("Spiritual",        habits.Count(h => h.Type == HabitType.Spiritual)),
    ];

    private static string GetHabitIcon(HabitType type) => type switch
    {
        HabitType.Physical        => "<i class=\"bi bi-activity\"></i>",
        HabitType.Mental          => "<i class=\"bi bi-lightbulb\"></i>",
        HabitType.SocialEmotional => "<i class=\"bi bi-people\"></i>",
        HabitType.Spiritual       => "<i class=\"bi bi-stars\"></i>",
        _                         => "<i class=\"bi bi-check-circle\"></i>"
    };
}
