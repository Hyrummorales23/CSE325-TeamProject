@inherits LayoutComponentBase

<div class="app-shell">
    <NavMenu />

    <div class="main-content">
        <header class="topbar">
            <span class="topbar-title">@GetTitle()</span>
            <span class="topbar-date">@DateTime.Now.ToString("dddd, MMMM d")</span>
        </header>

        <div class="page-body">
            <AppErrorBoundary>
                @Body
            </AppErrorBoundary>
        </div>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    Something went wrong.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">&#x2715;</span>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private string GetTitle()
    {
        return string.Empty; // individual pages set their own h1
    }
}
